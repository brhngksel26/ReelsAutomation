ENVIRONMENT=development

DB_USER=reels
DB_PASSWORD=reels_secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reels_automation
DB_SCHEMA=public
POSTGRES_CONTAINER_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_CACHE_EXPIRATION_SECONDS=3600
REDIS_DB=0
REDIS_CONTAINER_PORT=6379

JWT_ACCESS_SECRET_KEY=dev-access-secret-change-in-production
JWT_REFRESH_SECRET_KEY=dev-refresh-secret-change-in-production
ENCRYPTION_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
NEW_ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080
SESSION_SECRET_KEY=dev-session-secret
SESSION_EXPIRE_HOURS=24

CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/0

ENABLE_RATE_LIMITING=false
WEB_CONTAINER_PORT=8000

# LLM (Ollama default)
LLM_PROVIDER=ollama
LLM_MODEL_NAME=gemma4:12b
LLM_API_BASE=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_VALIDATION_MAX_TOKENS=1024
LLM_SCRIPT_MAX_TOKENS=8192
LLM_UNLIMITED_OUTPUT=true
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# Cloud provider example (uncomment and set LLM_PROVIDER):
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=gpt-4o
# LLM_API_KEY=sk-...
# LLM_API_BASE=https://api.openai.com/v1

# MoneyPrinterTurbo
MPT_BASE_URL=http://localhost:8080
MPT_VOICE_NAME_EN=en-US-AriaNeural
# MPT_API_TOKEN=your-api-token
MPT_REQUEST_TIMEOUT=120
MPT_POLL_INTERVAL=5
MPT_POLL_TIMEOUT=600

# Platform OAuth (app-level credentials)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=

# Public CDN/base URL for locally stored videos (Instagram REELS require http(s) URL)
# PUBLIC_MEDIA_BASE_URL=https://cdn.example.com

# Pipeline Celery retry / broker visibility
PIPELINE_CELERY_MAX_RETRIES=5
PIPELINE_CELERY_RETRY_BACKOFF_MAX=600
PIPELINE_VISIBILITY_TIMEOUT=3600
PIPELINE_STALE_AFTER_MINUTES=30
PIPELINE_MAX_RETRIES=5

# RSS news feeds
RSS_ENABLED=true
RSS_SCRAPE_HOUR=6
RSS_REQUEST_TIMEOUT=30
RSS_MAX_ITEMS_PER_FEED=50
RSS_NEWS_MAX_AGE_DAYS=7
RSS_USER_AGENT=ReelsAutomation-RSS/1.0

# Pipeline notifications (ntfy.sh — ücretsiz, hesap gerekmez)
NTFY_ENABLED=true
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=reels-pipeline-change-me-to-random-string
